{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Open-LMX Employment Graph",
  "type": "object",
  "required": ["id", "type", "nodes", "edges"],
  "properties": {
    "id": {"type": "string"},
    "type": {"const": "EmploymentGraph"},
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type"],
        "properties": {
          "id": {"type": "string"},
          "type": {"type": "string"},
          "label": {"type": "string"},
          "attributes": {"type": "object"}
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to", "relation"],
        "properties": {
          "from": {"type": "string"},
          "to": {"type": "string"},
          "relation": {"type": "string"},
          "start_date": {"type": "string", "format": "date-time"},
          "end_date": {"type": "string", "format": "date-time"},
          "status": {"type": "string"},
          "compensation": {"type": "object"},
          "performance_rating": {"type": "number", "minimum": 0, "maximum": 5},
          "evidence": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "trust_model": {
      "type": "object",
      "properties": {
        "employer_verification": {"type": "string"},
        "worker_verification": {"type": "string"},
        "evidence_sources": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}
