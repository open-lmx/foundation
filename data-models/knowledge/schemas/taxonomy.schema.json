{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Open-LMX Taxonomy",
  "type": "object",
  "required": ["id", "type", "name"],
  "properties": {
    "id": {"type": "string"},
    "type": {"const": "Taxonomy"},
    "name": {"type": "string"},
    "description": {"type": "string"},
    "categories": {
      "type": "array",
      "items": {"type": "string"}
    },
    "hierarchy": {"type": "object"},
    "version": {"type": "string"}
  }
}
