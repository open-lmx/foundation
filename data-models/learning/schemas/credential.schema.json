{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Open-LMX Credential",
  "type": "object",
  "required": ["id", "type", "name"],
  "properties": {
    "id": {"type": "string"},
    "type": {"const": "Credential"},
    "name": {"type": "string"},
    "description": {"type": "string"},
    "proves": {"type": "array", "items": {"type": "string"}},
    "issuer": {"type": "string"},
    "validity_period": {"type": "string"},
    "verification_method": {"type": "string"},
    "renewal_required": {"type": "boolean"}
  }
}
