{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Open-LMX Learning Objective",
  "type": "object",
  "required": ["id", "type", "statement"],
  "properties": {
    "id": {"type": "string"},
    "type": {"const": "LearningObjective"},
    "statement": {"type": "string"},
    "description": {"type": "string"},
    "aligned_competencies": {"type": "array", "items": {"type": "string"}},
    "aligned_concepts": {"type": "array", "items": {"type": "string"}},
    "measurable": {"type": "boolean"},
    "success_criteria": {"type": "array", "items": {"type": "string"}}
  }
}
