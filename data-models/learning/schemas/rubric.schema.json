{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Open-LMX Rubric",
  "type": "object",
  "required": ["id", "type", "name", "criteria"],
  "properties": {
    "id": {"type": "string"},
    "type": {"const": "Rubric"},
    "name": {"type": "string"},
    "description": {"type": "string"},
    "criteria": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": {"type": "string"},
          "name": {"type": "string"},
          "description": {"type": "string"},
          "weight": {"type": "number"},
          "levels": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "scale": {"type": "string"},
    "passing_threshold": {"type": "number"}
  }
}
