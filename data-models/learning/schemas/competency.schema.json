{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Open-LMX Competency",
  "type": "object",
  "required": ["id","name"],
  "properties": {
    "id": {"type":"string"},
    "name": {"type":"string"},
    "description": {"type":"string"},
    "skills": {"type":"array","items":{"type":"string"}},
    "capabilities": {"type":"array","items":{"type":"string"}},
    "proficiency_levels": {
      "type":"array",
      "items":{"type":"string"}
    },
    "evidence_required": {
      "type":"array",
      "items":{"type":"string"}
    }
  }
}
