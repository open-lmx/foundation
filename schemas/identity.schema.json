{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-lmx.org/schemas/identity.schema.json",
  "title": "Open-LMX Identity",
  "description": "Persistent identity schema for Open-LMX assets.",
  "type": "object",
  "required": [
    "id",
    "subject",
    "issuer",
    "type",
    "created_at",
    "status"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Stable identity identifier. DID, URI, UUID, or organization-scoped ID."
    },
    "subject": {
      "type": "string",
      "description": "Asset or entity this identity identifies."
    },
    "issuer": {
      "type": "string",
      "description": "Authority that issued the identity."
    },
    "type": {
      "type": "string",
      "enum": [
        "did",
        "uri",
        "uuid",
        "organization_scoped",
        "verifiable_credential"
      ]
    },
    "verification_method": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "active",
        "suspended",
        "revoked",
        "expired",
        "archived"
      ]
    },
    "claims": {
      "type": "object"
    },
    "metadata": {
      "type": "object"
    }
  }
}
